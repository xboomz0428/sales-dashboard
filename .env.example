# 複製本檔為 .env 後填入實際值（.env 已被 git 忽略，不會上傳）

# ── 前端 / 儀表板（Supabase）──────────────────────────────────
VITE_SUPABASE_URL=https://rwmepdmsqtipznzuajkn.supabase.co
VITE_SUPABASE_ANON_KEY=（Supabase 專案的 anon key）
# 匯入腳本(erp-import / lc-import / import-costs)寫入資料庫需要 service key：
VITE_SUPABASE_SERVICE_KEY=（Supabase 專案的 service_role key）

# ── LC / ERP 資料庫（MariaDB, lcdata）──────────────────────────
# 在 ERP 主機(WESMILE_S1-PC)上執行時設為 localhost 最單純（本機連本機、天生有權限）
LC_DB_HOST=localhost
LC_DB_PORT=3306
LC_DB_USER=（ERP 的資料庫帳號）
LC_DB_PASS=（ERP 的資料庫密碼）
LC_DB_NAME=lcdata
